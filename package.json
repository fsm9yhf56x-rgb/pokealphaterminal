{
  "name": "pokealphaterminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "sync-data": "node scripts/sync-tcgdex.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:types": "supabase gen types typescript --linked > src/lib/db/schema.ts && echo \"✅ src/lib/db/schema.ts regenerated\"",
    "psa:scrape": "node scripts/scrape-psa-set.mjs",
    "psa:scrape:hot": "node scripts/scrape-psa-tier.mjs --tier=hot",
    "psa:scrape:warm": "node scripts/scrape-psa-tier.mjs --tier=warm",
    "psa:scrape:cold": "node scripts/scrape-psa-tier.mjs --tier=cold",
    "psa:scrape:jp:hot": "node scripts/scrape-psa-tier-jp.mjs --tier=hot",
    "psa:scrape:jp:warm": "node scripts/scrape-psa-tier-jp.mjs --tier=warm",
    "psa:scrape:jp:cold": "node scripts/scrape-psa-tier-jp.mjs --tier=cold"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "html2canvas": "^1.4.1",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8",
    "prettier": "^3.2.5",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
